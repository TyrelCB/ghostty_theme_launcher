#!/usr/bin/env python3

import os
import sys

try:
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, Gtk, Pango
except Exception:
    sys.exit(3)


RANDOM_LABEL = "Random"
DEFAULT_THEME = "Vibrant Ink"
FALLBACK_THEME = {
    "background": "#10151d",
    "foreground": "#e6edf3",
    "cursor-color": "#ffb454",
    "cursor-text": "#10151d",
    "selection-background": "#334155",
    "selection-foreground": "#f8fafc",
    "palette": {
        1: "#ff6b6b",
        2: "#8bd450",
        3: "#ffd166",
        4: "#7cc7ff",
        5: "#c099ff",
        6: "#67e8f9",
        8: "#7f8ea3",
    },
}


def theme_dirs():
    env_dir = os.environ.get("GHOSTTY_THEME_DIR")
    candidates = []
    if env_dir:
        candidates.extend([path for path in env_dir.split(":") if path])

    candidates.extend(
        [
            os.path.expanduser("~/.config/ghostty/themes"),
            os.path.expanduser("~/.local/share/ghostty/themes"),
            os.path.expanduser(
                "~/.local/share/flatpak/app/com.mitchellh.ghostty/current/active/files/share/ghostty/themes"
            ),
            "/usr/share/ghostty/themes",
            "/usr/local/share/ghostty/themes",
            "/var/lib/flatpak/app/com.mitchellh.ghostty/current/active/files/share/ghostty/themes",
            "/snap/ghostty/current/share/ghostty/themes",
        ]
    )
    return [path for path in candidates if os.path.isdir(path)]


def find_theme_file(theme_name):
    for base in theme_dirs():
        candidate = os.path.join(base, theme_name)
        if os.path.isfile(candidate):
            return candidate
    return None


def parse_theme(theme_name):
    theme_path = find_theme_file(theme_name)
    theme_data = {
        "background": FALLBACK_THEME["background"],
        "foreground": FALLBACK_THEME["foreground"],
        "cursor-color": FALLBACK_THEME["cursor-color"],
        "cursor-text": FALLBACK_THEME["cursor-text"],
        "selection-background": FALLBACK_THEME["selection-background"],
        "selection-foreground": FALLBACK_THEME["selection-foreground"],
        "palette": dict(FALLBACK_THEME["palette"]),
        "path": theme_path or "Theme file not found",
    }

    if not theme_path:
        return theme_data

    with open(theme_path, "r", encoding="utf-8") as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue

            key, value = [part.strip() for part in line.split("=", 1)]
            if key == "palette" and "=" in value:
                index_text, color = [part.strip() for part in value.split("=", 1)]
                try:
                    theme_data["palette"][int(index_text)] = color
                except ValueError:
                    continue
                continue

            if key in theme_data:
                theme_data[key] = value

    return theme_data


def markup_escape(text):
    return (
        text.replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
    )


def rgba(color_value):
    parsed = Gdk.RGBA()
    if parsed.parse(color_value):
        return parsed
    fallback = Gdk.RGBA()
    fallback.parse("#000000")
    return fallback


def palette_color(theme_data, index, fallback):
    return theme_data["palette"].get(index, fallback)


class ThemePicker:
    def __init__(self, themes):
        self.themes = [RANDOM_LABEL] + list(themes)
        self.selection = None
        self.result = None
        self.exit_code = 1
        self.preview_css = Gtk.CssProvider()

        self.window = Gtk.Window(title="Ghostty Theme Launcher")
        self.window.set_default_size(1120, 760)
        self.window.set_border_width(14)
        self.window.set_role("ghostty-theme-launcher")
        self.window.set_type_hint(Gdk.WindowTypeHint.NORMAL)
        self.window.set_skip_taskbar_hint(False)
        self.window.set_skip_pager_hint(False)
        self.window.set_icon_name("ghostty-theme-launcher")
        self.window.set_wmclass("ghostty-theme-launcher", "GhosttyThemeLauncher")

        launch_button = Gtk.Button.new_with_label("Launch")
        launch_button.get_style_context().add_class("suggested-action")
        launch_button.connect("clicked", self.on_launch)
        self.window.set_default(launch_button)

        cancel_button = Gtk.Button.new_with_label("Cancel")
        cancel_button.connect("clicked", self.on_cancel)

        screen = Gdk.Screen.get_default()
        if screen is not None:
            Gtk.StyleContext.add_provider_for_screen(
                screen,
                self.preview_css,
                Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
            )

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        content.set_hexpand(True)
        content.set_vexpand(True)
        self.window.add(content)
        content.set_spacing(14)

        layout = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        layout.set_hexpand(True)
        layout.set_vexpand(True)
        content.pack_start(layout, True, True, 0)

        layout.pack_start(self.build_theme_list(), False, False, 0)
        layout.pack_start(self.build_preview_panel(), True, True, 0)

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.set_halign(Gtk.Align.END)
        actions.pack_start(cancel_button, False, False, 0)
        actions.pack_start(launch_button, False, False, 0)
        content.pack_start(actions, False, False, 0)

        self.window.connect("delete-event", self.on_delete)
        self.window.connect("key-press-event", self.on_key_press)

        self.select_theme(DEFAULT_THEME)
        self.tree.grab_focus()

    def build_theme_list(self):
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        outer.set_size_request(280, -1)
        outer.set_vexpand(True)

        heading = Gtk.Label()
        heading.set_markup("<b>Themes</b>")
        heading.set_xalign(0)
        outer.pack_start(heading, False, False, 0)

        subheading = Gtk.Label(
            label="Pick a theme on the left and review the preview pane before launching."
        )
        subheading.set_xalign(0)
        subheading.set_line_wrap(True)
        subheading.set_max_width_chars(28)
        outer.pack_start(subheading, False, False, 0)

        self.store = Gtk.ListStore(str)
        for theme in self.themes:
            self.store.append([theme])

        self.tree = Gtk.TreeView(model=self.store)
        self.tree.set_headers_visible(False)
        self.tree.set_enable_search(True)
        self.tree.set_search_column(0)

        column = Gtk.TreeViewColumn("Theme", Gtk.CellRendererText(), text=0)
        column.set_expand(True)
        self.tree.append_column(column)

        selection = self.tree.get_selection()
        selection.connect("changed", self.on_selection_changed)
        self.tree.connect("row-activated", self.on_row_activated)

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        scroll.set_hexpand(True)
        scroll.set_vexpand(True)
        scroll.set_min_content_height(520)
        scroll.add(self.tree)
        outer.pack_start(scroll, True, True, 0)

        return outer

    def build_preview_panel(self):
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        outer.set_hexpand(True)
        outer.set_vexpand(True)

        heading = Gtk.Label()
        heading.set_markup("<b>Preview</b>")
        heading.set_xalign(0)
        outer.pack_start(heading, False, False, 0)

        self.theme_name = Gtk.Label()
        self.theme_name.set_xalign(0)
        outer.pack_start(self.theme_name, False, False, 0)

        self.theme_path = Gtk.Label()
        self.theme_path.set_xalign(0)
        self.theme_path.set_selectable(True)
        self.theme_path.set_line_wrap(True)
        self.theme_path.set_max_width_chars(72)
        outer.pack_start(self.theme_path, False, False, 0)

        chips = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        self.swatches = {}
        for key, label in [
            ("background", "Background"),
            ("foreground", "Foreground"),
            ("cursor-color", "Cursor"),
            ("selection-background", "Selection"),
            ("palette-4", "Accent"),
        ]:
            chips.pack_start(self.build_swatch(key, label), True, True, 0)
        outer.pack_start(chips, False, False, 0)

        terminal_frame = Gtk.Frame()
        terminal_frame.set_shadow_type(Gtk.ShadowType.NONE)
        terminal_frame.set_hexpand(True)
        terminal_frame.set_vexpand(True)
        terminal_frame.set_size_request(-1, 320)
        outer.pack_start(terminal_frame, True, True, 0)

        terminal_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        terminal_box.set_name("preview-terminal")
        terminal_box.set_hexpand(True)
        terminal_box.set_vexpand(True)
        terminal_frame.add(terminal_box)

        titlebar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        titlebar.set_name("preview-titlebar")
        titlebar.set_margin_top(14)
        titlebar.set_margin_start(16)
        titlebar.set_margin_end(16)
        titlebar.set_margin_bottom(10)
        terminal_box.pack_start(titlebar, False, False, 0)

        title_label = Gtk.Label(label="ghostty")
        title_label.set_xalign(0)
        title_label.set_name("preview-title")
        titlebar.pack_start(title_label, False, False, 0)

        sample = Gtk.TextView()
        sample.set_name("preview-sample")
        sample.set_editable(False)
        sample.set_cursor_visible(False)
        sample.set_wrap_mode(Gtk.WrapMode.NONE)
        sample.set_monospace(True)
        sample.set_hexpand(True)
        sample.set_vexpand(True)
        sample.set_left_margin(16)
        sample.set_right_margin(16)
        sample.set_top_margin(6)
        sample.set_bottom_margin(16)
        sample.override_font(Pango.FontDescription("Monospace 11"))

        sample_scroll = Gtk.ScrolledWindow()
        sample_scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        sample_scroll.set_shadow_type(Gtk.ShadowType.NONE)
        sample_scroll.set_hexpand(True)
        sample_scroll.set_vexpand(True)
        sample_scroll.set_min_content_height(260)
        sample_scroll.add(sample)
        terminal_box.pack_start(sample_scroll, True, True, 0)
        self.sample = sample
        self.sample_buffer = sample.get_buffer()

        hint = Gtk.Label(
            label="Double-click a theme to launch immediately, or use Launch."
        )
        hint.set_xalign(0)
        outer.pack_start(hint, False, False, 0)

        return outer

    def build_swatch(self, key, label):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)

        chip = Gtk.EventBox()
        chip.set_name(f"swatch-{key}")
        chip.set_size_request(-1, 34)
        box.pack_start(chip, False, False, 0)

        title = Gtk.Label(label=label)
        title.set_xalign(0)
        box.pack_start(title, False, False, 0)

        value = Gtk.Label(label="#000000")
        value.set_xalign(0)
        box.pack_start(value, False, False, 0)

        self.swatches[key] = (chip, value)
        return box

    def select_theme(self, theme_name):
        for index, row in enumerate(self.store):
            if row[0] == theme_name:
                path = Gtk.TreePath(index)
                self.tree.set_cursor(path)
                self.tree.scroll_to_cell(path, None, False, 0, 0)
                self.selection = theme_name
                self.refresh_preview(theme_name)
                return

    def on_selection_changed(self, tree_selection):
        model, tree_iter = tree_selection.get_selected()
        if tree_iter is None:
            return
        theme_name = model[tree_iter][0]
        self.selection = theme_name
        self.refresh_preview(theme_name)

    def on_row_activated(self, *_args):
        self.on_launch()

    def on_key_press(self, _widget, event):
        if event.keyval == Gdk.KEY_Escape:
            self.on_cancel()
            return True
        if event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            self.on_launch()
            return True
        return False

    def on_cancel(self, *_args):
        self.exit_code = 1
        Gtk.main_quit()

    def on_launch(self, *_args):
        if not self.selection:
            return
        self.result = self.selection
        self.exit_code = 0
        Gtk.main_quit()

    def on_delete(self, *_args):
        self.exit_code = 1
        Gtk.main_quit()
        return False

    def ensure_tag(self, name, **properties):
        tag_table = self.sample_buffer.get_tag_table()
        tag = tag_table.lookup(name)
        if tag is None:
            tag = self.sample_buffer.create_tag(name)
        for key, value in properties.items():
            tag.set_property(key, value)
        return tag

    def apply_preview_tags(self, theme_data):
        self.ensure_tag("default", foreground=theme_data["foreground"])
        self.ensure_tag(
            "prompt",
            foreground=palette_color(theme_data, 2, theme_data["cursor-color"]),
            weight=Pango.Weight.BOLD,
        )
        self.ensure_tag(
            "command",
            foreground=theme_data["foreground"],
            weight=Pango.Weight.BOLD,
        )
        self.ensure_tag(
            "flag",
            foreground=palette_color(theme_data, 3, theme_data["foreground"]),
        )
        self.ensure_tag(
            "string",
            foreground=palette_color(theme_data, 2, theme_data["foreground"]),
        )
        self.ensure_tag(
            "keyword",
            foreground=palette_color(theme_data, 5, theme_data["foreground"]),
            weight=Pango.Weight.BOLD,
        )
        self.ensure_tag(
            "function",
            foreground=palette_color(theme_data, 4, theme_data["foreground"]),
        )
        self.ensure_tag(
            "type",
            foreground=palette_color(theme_data, 6, theme_data["foreground"]),
        )
        self.ensure_tag(
            "comment",
            foreground=palette_color(theme_data, 8, theme_data["selection-background"]),
            style=Pango.Style.ITALIC,
        )
        self.ensure_tag(
            "number",
            foreground=palette_color(theme_data, 3, theme_data["foreground"]),
        )
        self.ensure_tag(
            "path",
            foreground=palette_color(theme_data, 4, theme_data["foreground"]),
        )
        self.ensure_tag(
            "added",
            foreground=palette_color(theme_data, 2, theme_data["foreground"]),
        )
        self.ensure_tag(
            "removed",
            foreground=palette_color(theme_data, 1, theme_data["foreground"]),
        )
        self.ensure_tag(
            "accent",
            foreground=palette_color(theme_data, 6, theme_data["foreground"]),
            weight=Pango.Weight.BOLD,
        )
        self.ensure_tag(
            "selection",
            foreground=theme_data["selection-foreground"],
            background=theme_data["selection-background"],
        )
        self.ensure_tag(
            "cursor",
            foreground=theme_data["cursor-text"],
            background=theme_data["cursor-color"],
            weight=Pango.Weight.BOLD,
        )

    def append_segments(self, segments):
        insert_iter = self.sample_buffer.get_end_iter()
        for text, tag_name in segments:
            if tag_name is None:
                self.sample_buffer.insert(insert_iter, text)
            else:
                self.sample_buffer.insert_with_tags_by_name(insert_iter, text, tag_name)

    def refresh_preview(self, theme_name):
        if theme_name == RANDOM_LABEL:
            theme_data = dict(FALLBACK_THEME)
            theme_data["palette"] = dict(FALLBACK_THEME["palette"])
            theme_data["path"] = "Launches a random theme from the curated list."
            display_name = RANDOM_LABEL
        else:
            theme_data = parse_theme(theme_name)
            display_name = theme_name

        self.theme_name.set_markup(
            f"<span size='x-large'><b>{markup_escape(display_name)}</b></span>"
        )
        self.theme_path.set_text(theme_data["path"])

        accent_color = theme_data["palette"].get(4, theme_data["cursor-color"])
        swatch_values = {
            "background": theme_data["background"],
            "foreground": theme_data["foreground"],
            "cursor-color": theme_data["cursor-color"],
            "selection-background": theme_data["selection-background"],
            "palette-4": accent_color,
        }
        for key, value in swatch_values.items():
            _chip, label = self.swatches[key]
            label.set_text(value)

        self.sample.override_background_color(
            Gtk.StateFlags.NORMAL, rgba(theme_data["background"])
        )
        self.sample.override_color(Gtk.StateFlags.NORMAL, rgba(theme_data["foreground"]))
        self.apply_preview_tags(theme_data)

        self.sample_buffer.set_text("")
        preview_lines = [
            [
                ("$ ", "prompt"),
                ("ghostty", "command"),
                (" --theme ", "flag"),
                (f"\"{display_name}\"", "string"),
                (" --title ", "flag"),
                (f"\"{display_name} - ~/projects\"", "string"),
            ],
            [
                ("$ ", "prompt"),
                ("rg", "command"),
                (" -n ", "flag"),
                ("\"palette\"", "string"),
                (" ", None),
                (theme_data["path"], "path"),
            ],
            [("", None)],
            [
                ("def ", "keyword"),
                ("launch_preview", "function"),
                ("(", None),
                ("theme_name", "accent"),
                (": ", None),
                ("str", "type"),
                (") -> ", None),
                ("None", "type"),
                (":", None),
            ],
            [
                ("    if ", "keyword"),
                ("theme_name", "accent"),
                (" == ", None),
                ("\"Random\"", "string"),
                (":", None),
            ],
            [
                ("        return ", "keyword"),
                ("choose_theme", "function"),
                ("()", None),
            ],
            [
                ("    print", "function"),
                ("(", None),
                ("\"Preview section active\"", "string"),
                (")", None),
            ],
            [("", None)],
            [("@@ theme preview @@\n", "comment")],
            [("+ syntax colors follow the selected theme palette", "added")],
            [("- flat monochrome sample text", "removed")],
            [
                ("selected text", "selection"),
                ("  ", None),
                ("cursor", "cursor"),
                ("  ", None),
                ("accent", "accent"),
            ],
        ]

        for line in preview_lines:
            self.append_segments(line)
            self.sample_buffer.insert(self.sample_buffer.get_end_iter(), "\n")

        css = f"""
        #preview-terminal {{
            background: {theme_data['background']};
            border-radius: 14px;
            border: 1px solid {theme_data['selection-background']};
        }}
        #preview-titlebar {{
            background: {theme_data['selection-background']};
            border-top-left-radius: 14px;
            border-top-right-radius: 14px;
        }}
        #preview-title,
        #preview-sample {{
            color: {theme_data['foreground']};
        }}
        #swatch-background {{
            background: {theme_data['background']};
            border-radius: 8px;
            border: 1px solid {theme_data['selection-background']};
        }}
        #swatch-foreground {{
            background: {theme_data['foreground']};
            border-radius: 8px;
            border: 1px solid {theme_data['selection-background']};
        }}
        #swatch-cursor-color {{
            background: {theme_data['cursor-color']};
            border-radius: 8px;
            border: 1px solid {theme_data['selection-background']};
        }}
        #swatch-selection-background {{
            background: {theme_data['selection-background']};
            border-radius: 8px;
            border: 1px solid {theme_data['selection-background']};
        }}
        #swatch-palette-4 {{
            background: {accent_color};
            border-radius: 8px;
            border: 1px solid {theme_data['selection-background']};
        }}
        """
        self.preview_css.load_from_data(css.encode("utf-8"))

    def run(self):
        self.window.show_all()
        self.window.present()
        Gtk.main()
        if self.result is not None:
            print(self.result)
        return self.exit_code


def main(argv):
    if not os.environ.get("DISPLAY") and not os.environ.get("WAYLAND_DISPLAY"):
        return 3

    themes = argv[1:]
    if not themes:
        return 3

    picker = ThemePicker(themes)
    return picker.run()


if __name__ == "__main__":
    sys.exit(main(sys.argv))
